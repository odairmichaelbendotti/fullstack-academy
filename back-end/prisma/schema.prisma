generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model User {
  id          String   @id @default(uuid())
  name        String
  lastName    String
  email       String   @unique
  phone       String
  birthDate   DateTime
  password    String
  acceptTerms Boolean
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}
